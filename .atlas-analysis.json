  "keyFeatures": [
    "User authentication with OTP verification",
    "Role-based access (User and Worker roles)",
    "Event ticket browsing and purchasing",
    "Shopping cart management with local persistence",
    "QR code generation and scanning for tickets",
    "Profile management with image upload",
    "Ticket validation for workers",
    "Offline session persistence with DataStore"
